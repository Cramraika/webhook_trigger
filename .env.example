# Rate Limiting
BASE_RATE_LIMIT=3
STARTING_RATE_LIMIT=3
MAX_RATE_LIMIT=5.0
WINDOW_SIZE=20
ERROR_THRESHOLD=0.3
MAX_WORKERS=3
SKIP_ROWS=0
KEEP_ALIVE=true

# Deployment
DEPLOYMENT_MODE=

# n8n Workflow Automation
N8N_WEBHOOK_URL=https://n8n.chinmayramraika.in
N8N_API_KEY=your-project-specific-n8n-api-key
